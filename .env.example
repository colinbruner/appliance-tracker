# OIDC Provider — required for login
# Works with any OIDC-compliant provider (Auth0, Google, Keycloak, Okta, Pocket ID, etc.)
VITE_OIDC_AUTHORITY=https://your-provider.example.com
VITE_OIDC_CLIENT_ID=your-client-id

# Register redirect URI: http://localhost:5173/callback (dev)
# and: https://your-app.com/callback (production)

# Supabase — required for remote storage (production)
# If not set, localStorage is used (local dev / demo mode)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
